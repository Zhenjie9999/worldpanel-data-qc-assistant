# Copy this file to /etc/worldpanel-qc.env on the cloud server.
# Fill in real values on the server. Do not publish this file with secrets.

WORLDPANEL_QC_ACCESS_PASSWORD=change-this-shared-password

WORLDPANEL_QC_ALLOW_LLM_SETTINGS=0
WORLDPANEL_QC_COOKIE_SECURE=1
WORLDPANEL_QC_MAX_REQUEST_BYTES=157286400

WORLDPANEL_QC_LLM_ENDPOINT=http://218.241.201.171:28180/jdgpt/v1/chat/completions
WORLDPANEL_QC_LLM_MODEL=gpt-5.4
WORLDPANEL_QC_LLM_TOKEN=paste-model-token-here
WORLDPANEL_QC_LLM_TIMEOUT_SECONDS=90
WORLDPANEL_QC_LLM_ENABLED=1
WORLDPANEL_QC_LLM_OCR_ENABLED=1
